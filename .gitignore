# Binary builds
# Ignora o executável principal gerado pelo 'go build'
/monitor-agent
/*.exe
/*.exe~
/*.dll
/*.so
/*.dylib

# Build directory (caso você use uma pasta separada para outputs)
bin/
dist/
out/

# Dependency directories
# Go modules cuidam disso, mas se você usar 'go mod vendor', 
# decida se quer ou não versionar a pasta vendor. Geralmente ignoramos.
vendor/

# Environment variables (EXTREMAMENTE IMPORTANTE)
# Nunca suba seus tokens ou URLs de produção
.env
.env.local
.env.*.local

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Logs
*.log

# Docker (caso gere imagens locais ou arquivos de cache)
.docker/